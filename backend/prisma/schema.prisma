generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// models

enum EmployeeStatus {
  pending
  active
  inactive
  suspended
}

enum CompanyStatus {
  pending
  active
  inactive
  suspended
}

model Company {
  id          String @id @default(uuid())

  name        String
  email       String @unique
  password    String
  role        String @default("admin")
  status      CompanyStatus @default(active)

  employees   Employee[]
  roles       Role[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

   deletedAt   DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([status, createdAt])
}

model Employee {
  id          String   @id @default(uuid())

  company_id  String
  company     Company  @relation(fields: [company_id], references: [id])

  name        String
  email       String  
  password    String

  status      EmployeeStatus   @default(pending)

  avatar_url  Json?

  role_id     Int     
  role        Role     @relation(fields: [role_id], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([company_id, email])
  @@index([company_id, createdAt])
  @@index([company_id, status, createdAt])
  @@index([company_id, role_id, createdAt])
}


model Role {
  id          Int    @id @default(autoincrement())
  name        String 
  created_by  String? 
  company Company? @relation(fields: [created_by], references: [id])

  permissions Permission[] 
  employees   Employee[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([created_by])
  @@unique([created_by, name])
}

model Permission {
  id          Int    @id @default(autoincrement())
  module      String
  action      String
  description String?

  roles       Role[]

  @@unique([module, action])
}