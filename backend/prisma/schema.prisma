generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

 // models

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String 
  status    String   @default("active")
  avatar_url    Json?
  createdAt DateTime @default(now())
}

model Role {
  id Int @id @default(autoincrement())
  name String @unique
}